# ==============================================================================
# Narayan Pharmacy Task - Environment Configuration Example
# Copy this file to:
#   1. backend/.env (for Django backend configuration)
#   2. frontend/.env (for Next.js frontend configuration)
# ==============================================================================

# --- BACKEND CONFIGURATION (place inside backend/.env) ---
# Django Secret Key (a default dummy key is provided for local testing)
SECRET_KEY=django-insecure-dummy-key-for-local-testing
DEBUG=True
ALLOWED_HOSTS=*
CORS_ALLOW_ALL_ORIGINS=True

# Claude API Key (Required to check interactions; replace with your real key)
ANTHROPIC_API_KEY=your_anthropic_api_key_here


# --- FRONTEND CONFIGURATION (place inside frontend/.env) ---
# Next.js API endpoint pointing to the Django backend server
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
